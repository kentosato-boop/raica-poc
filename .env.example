RAICA_ENVIRONMENT=development
RAICA_DATABASE_URL=sqlite:///data/raica.sqlite3
RAICA_API_KEY=
RAICA_CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:8000
RAICA_BOOTSTRAP_SCHEMA_ENABLED=true
RAICA_DEMO_SEED_ENABLED=true
RAICA_STARTUP_MATCHING_ENABLED=true
RAICA_SKILL_SHEET_STORAGE_DIR=data/skill_sheets

# Porters read synchronization. Endpoints must return an array or {"items": [...]}.
RAICA_PORTERS_CANDIDATES_URL=
RAICA_PORTERS_JOBS_URL=
RAICA_PORTERS_TOKEN=

# Outbound integration gateways. RAiCA posts signed-off events to these URLs.
RAICA_GMAIL_WEBHOOK_URL=
RAICA_GMAIL_ACCESS_TOKEN=
RAICA_GMAIL_SENDER=
RAICA_ZALO_WEBHOOK_URL=
RAICA_ASANA_WEBHOOK_URL=
RAICA_INTEGRATION_TIMEOUT_SECONDS=15

# Set only when RAICA_API_KEY is enabled.
VITE_RAICA_API_KEY=
